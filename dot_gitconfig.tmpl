{{- $name := get . "name" | default "" -}}
{{- $email := get . "email" | default "" -}}
{{- $hosttype := get . "hosttype" | default "server" -}}
{{- $company := get . "company" | default "" -}}
# Default settings
[user]
  name = {{ $name | quote }}
  email = {{ $email | quote }}

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

{{- if and (eq $hosttype "workstation") (ne $company "") }}
# Load based on directory
[includeIf "gitdir:~/{{ $company }}/**"]
    path = .gitconfig-work
{{- end }}

{{- $hosttype := get . "hosttype" | default "server" -}}
{{- if eq $hosttype "workstation" -}}
{
  "chat.viewSessions.orientation": "stacked",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "'SauceCodePro Nerd Font', 'Courier New', monospace",
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": true
  },
  "editor.tabSize": 2,
  "files.associations": {
    "*.css": "tailwindcss",
    "*.scss": "tailwindcss"
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "github.copilot.enable": {
    "*": true,
    "markdown": false,
    "plaintext": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "go.toolsManagement.autoUpdate": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "mdb.mcp.server": "autoStartDisabled",
  "prettier.resolveGlobalModules": true,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "window.restoreWindows": "preserve",
  "workbench.colorTheme": "Monokai Pro (Filter Spectrum)",
  "workbench.iconTheme": "Monokai Pro (Filter Spectrum) Icons",
  "workbench.startupEditor": "none",
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "[opentofu]": {
    "editor.defaultFormatter": "opentofu.vscode-opentofu"
  },
  "[gotmpl]": {
    "editor.defaultFormatter": "golang.go"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  }
}
{{ end -}}